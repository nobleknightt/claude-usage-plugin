{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv",
            "args": ["run", "--project", "${CLAUDE_PLUGIN_ROOT}/scripts", "python", "${CLAUDE_PLUGIN_ROOT}/scripts/track.py"],
            "async": true,
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv",
            "args": ["run", "--project", "${CLAUDE_PLUGIN_ROOT}/scripts", "python", "${CLAUDE_PLUGIN_ROOT}/scripts/sync.py"],
            "async": true,
            "timeout": 60
          }
        ]
      }
    ]
  }
}
