# Copy to .env and fill in. .env is gitignored and not baked into the image.

# --- Storage ---
# SQLite path. Compose overrides this to a mounted volume (/data/usage.db).
DATABASE=usage.db

# --- Microsoft Entra ID (Azure AD) app registration ---
# Create an app registration in the Azure portal; add the redirect URI below
# as a "Web" platform redirect and generate a client secret.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:8000/api/auth/microsoft/callback

# Where the browser lands after a successful login (the SPA).
FRONTEND_URL=/

# --- Sessions ---
# Signs the session cookie (and the JWT it carries). Use a long random string
# in production; if unset a random one is generated per process (sessions drop
# on restart). Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# --- Authorization ---
# Comma-separated admin allowlist, matched against the Entra-verified email.
ADMIN_EMAILS=

# Comma-separated browser origins allowed to call the API with credentials.
# Include the Vite dev server for local development.
CORS_ORIGINS=http://localhost:5173,http://localhost:8000
